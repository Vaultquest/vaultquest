# Action ledger (issue #34)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/vaultquest
INTERNAL_SERVICE_SECRET=change-me-to-a-long-random-string
# Replace the placeholder secret with a strong, unique value. The backend rejects placeholder values at boot.
ORPHAN_TTL_MINUTES=10
LOG_LEVEL=info
PORT=3001
NODE_ENV=development

# API key for external/third-party service endpoints (issue #273).
# When set, all /api/* routes require the header: X-Api-Key: <value>
# Must be at least 32 characters. Leave unset to disable enforcement in local dev.
# API_KEY=change-me-to-a-long-random-api-key-string

# Activity export authorization (issue #10).
# How long a signed wallet export challenge stays valid, in milliseconds.
# Wide enough to absorb browser/server clock skew, short enough that a captured
# signature is not useful for long. Default 5 minutes (300000).
# EXPORT_SIGNATURE_TTL_MS=300000

# Automated database backups (issue #275).
# BACKUP_DIR: absolute path where pg_dump files are written.
#   When unset the backup cron is not started and the backup script exits early.
# BACKUP_RETAIN_DAYS: delete backup files older than this many days (default 7).
# BACKUP_SCHEDULE: cron expression for the automated backup job (default: daily at 02:00).
#   Uses standard 5-field cron syntax supported by node-cron.
# BACKUP_DIR=/var/backups/vaultquest
# BACKUP_RETAIN_DAYS=7
# BACKUP_SCHEDULE=0 2 * * *
