generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ActionType {
  deposit
  withdraw
  create_vault
  claim
  select_winner
}

enum ActionStatus {
  pending
  submitted
  confirmed
  failed
  reverted
  orphaned
}

model ActionLedger {
  id                String       @id @default(uuid()) @db.Uuid
  idempotencyKey    String       @unique @map("idempotency_key")
  walletAddress     String       @map("wallet_address")
  actionType        ActionType   @map("action_type")
  actionPayload     Json?        @map("action_payload")
  status            ActionStatus @default(pending)
  txHash            String?      @unique @map("tx_hash")
  sorobanEventId    String?      @map("soroban_event_id")
  correlationId     String       @default(uuid()) @map("correlation_id") @db.Uuid
  errorCode         String?      @map("error_code")
  errorDetail       String?      @map("error_detail")
  retryCount        Int          @default(0) @map("retry_count")
  redactedAt        DateTime?    @map("redacted_at")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")
  submittedAt       DateTime?    @map("submitted_at")
  confirmedAt       DateTime?    @map("confirmed_at")

  @@index([walletAddress, createdAt(sort: Desc)])
  @@index([status, updatedAt])
  @@index([walletAddress, actionType])
  @@index([status, createdAt(sort: Desc)])
  @@map("action_ledger")
}

model PendingEvent {
  txHash          String    @id @map("tx_hash")
  sorobanEventId  String    @map("soroban_event_id")
  eventPayload    Json      @map("event_payload")
  statusHint      String    @map("status_hint")
  receivedAt      DateTime  @default(now()) @map("received_at")
  consumedAt      DateTime? @map("consumed_at")

  @@index([statusHint, receivedAt])
  @@map("pending_events")
}

model IndexerCheckpoint {
  id                  String   @id @default("singleton")
  latestLedger        Int      @map("latest_ledger")
  lastProcessedEventId String?  @map("last_processed_event_id")
  lastSyncTime        DateTime @map("last_sync_time")
  lastError           String?  @map("last_error")
  lastSuccessSyncTime DateTime @default(now()) @map("last_success_sync_time")

  @@map("indexer_checkpoints")
}

model VaultSettlement {
  id             String    @id @default(uuid()) @db.Uuid
  vaultId        String    @unique @map("vault_id")
  state          String    @default("Unresolved")
  settlementType String    @map("settlement_type")
  recipient      String?
  amount         String?
  txHash         String?   @unique @map("tx_hash")
  resultCode     String?   @map("result_code")
  errorCode      String?   @map("error_code")
  errorDetail    String?   @map("error_detail")
  attempts       Int       @default(0)
  resolvedAt     DateTime? @map("resolved_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([state, updatedAt])
  @@index([recipient, state])
  @@map("vault_settlements")
}

model UserQuest {
  id                    String    @id @default(uuid()) @db.Uuid
  walletAddress         String    @map("wallet_address")
  questId               String    @map("quest_id")
  progress              Float     @default(0)
  target                Float
  status                String    @default("in_progress")
  metadata              Json?
  completedAt           DateTime? @map("completed_at")
  lastEvaluatedAt       DateTime  @default(now()) @map("last_evaluated_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@unique([walletAddress, questId])
  @@index([walletAddress, status])
  @@index([status, completedAt(sort: Desc)])
  @@map("user_quests")
}

model SavedPool {
  id               String   @id @default(uuid()) @db.Uuid
  walletAddress    String   @map("wallet_address")
  poolId           String   @map("pool_id")
  poolName         String   @map("pool_name")
  status           String
  tvl              String
  asset            String
  participantCount Int      @map("participant_count")
  expectedYield    String   @map("expected_yield")
  prize            String?
  opensAt          DateTime? @map("opens_at")
  locksAt          DateTime? @map("locks_at")
  drawsAt          DateTime? @map("draws_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@unique([walletAddress, poolId])
  @@index([walletAddress, createdAt(sort: Desc)])
  @@index([poolId])
  @@map("saved_pools")
}

model UserNotificationPref {
  id            String   @id @default(uuid()) @db.Uuid
  walletAddress String   @map("wallet_address")
  category      String
  encryptedPref Json     @map("encrypted_pref")
  keyVersion    Int      @default(1) @map("key_version")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([walletAddress, category])
  @@index([walletAddress])
  @@map("user_notification_prefs")
}

model UserSupportEvidence {
  id            String   @id @default(uuid()) @db.Uuid
  walletAddress String   @map("wallet_address")
  ticketId      String   @map("ticket_id")
  encryptedData Json     @map("encrypted_data")
  keyVersion    Int      @default(1) @map("key_version")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([walletAddress])
  @@map("user_support_evidence")
}

model UserActivityLog {
  id            String   @id @default(uuid()) @db.Uuid
  walletAddress String   @map("wallet_address")
  activityType  String   @map("activity_type")
  encryptedIp   Json?    @map("encrypted_ip")
  encryptedMeta Json?    @map("encrypted_meta")
  keyVersion    Int      @default(1) @map("key_version")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([walletAddress, createdAt(sort: Desc)])
  @@map("user_activity_logs")
}

model LegalHold {
  id            String    @id @default(uuid()) @db.Uuid
  walletAddress String    @unique @map("wallet_address")
  reason        String
  createdBy     String    @map("created_by")
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  releasedAt    DateTime? @map("released_at")

  @@index([walletAddress, active])
  @@map("legal_holds")
}

model DeletionManifest {
  id                String   @id @default(uuid()) @db.Uuid
  walletAddressHash String   @map("wallet_address_hash")
  status            String
  deletedCounts     Json     @map("deleted_counts")
  heldCounts        Json     @map("held_counts")
  manifestHash      String   @map("manifest_hash")
  keyVersion        Int      @default(1) @map("key_version")
  completedAt       DateTime @default(now()) @map("completed_at")

  @@index([walletAddressHash])
  @@map("deletion_manifests")
}

model BackupExpiryManifest {
  id                    String   @id @default(uuid()) @db.Uuid
  deletionManifestId    String   @map("deletion_manifest_id") @db.Uuid
  walletAddressHash     String   @map("wallet_address_hash")
  backupRetentionCutoff DateTime @map("backup_retention_cutoff")
  createdAt             DateTime @default(now()) @map("created_at")

  @@index([walletAddressHash])
  @@map("backup_expiry_manifests")
}

model PrivacyAuditLog {
  id               String   @id @default(uuid()) @db.Uuid
  action           String
  actorWalletHash  String?  @map("actor_wallet_hash")
  targetWalletHash String?  @map("target_wallet_hash")
  details          Json
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([action, createdAt(sort: Desc)])
  @@index([targetWalletHash])
  @@map("privacy_audit_logs")
}

